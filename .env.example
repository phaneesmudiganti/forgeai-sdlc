# Example environment variables for local development
# Copy this file to `.env` and fill in real values before running the app.

# Model names used by the project. Set these to the names supported by your LLM provider.
FAST_MODEL=qwen2.5-coder:1.5b
SMART_MODEL=qwen2.5-coder:1.5b

# LLM temperature (0.0 = deterministic, higher = more creative)
LLM_TEMPERATURE=0.2

# Provider API key (if required by the adapter in use). Keep this secret.
OPENAI_API_KEY=

# Optional: override Uvicorn host/port for local runs
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000